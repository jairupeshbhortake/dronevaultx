{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opendronelog.dev/context/schema/context-doc.schema.json",
  "title": "Context Domain Document",
  "type": "object",
  "required": [
    "id",
    "version",
    "title",
    "status",
    "owners",
    "verified_from",
    "content"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "integer", "minimum": 1 },
    "title": { "type": "string", "minLength": 1 },
    "status": { "enum": ["active", "draft", "deprecated"] },
    "owners": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "updated_at": { "type": "string", "format": "date-time" },
    "verified_from": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "note": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "content": { "type": "object" }
  },
  "additionalProperties": false
}
